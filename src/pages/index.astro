---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsFeed from '../components/NewsFeed.astro';
import fs from 'node:fs';
import path from 'node:path';

const categoriesPath = path.join(process.cwd(), 'config/categories.json');
const categoriesData = JSON.parse(fs.readFileSync(categoriesPath, 'utf-8'));
const categories = categoriesData.categories;

const indexPath = path.join(process.cwd(), 'data/index.json');
let editions: any[] = [];
let latestKey = '';
if (fs.existsSync(indexPath)) {
  const indexData = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
  editions = indexData.editions || [];
  latestKey = indexData.latest || '';

  if (!editions.length && indexData.dates) {
    editions = indexData.dates.map((d: string) => ({ date: d, edition: 'all', file: `${d}.json` }));
    latestKey = indexData.dates[0] || '';
  }
}

let articles: any[] = [];
let clusters: any[] = [];
let newsDate = '';
let edition = '';
let articleCount = 0;
let clusterCount = 0;

if (latestKey) {
  const dataPath = path.join(process.cwd(), `data/${latestKey}.json`);
  if (fs.existsSync(dataPath)) {
    const data = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
    articles = data.articles || [];
    clusters = data.clusters || [];
    newsDate = data.date || '';
    edition = data.edition || '';
    articleCount = data.article_count || articles.length;
    clusterCount = data.cluster_count || clusters.length || articles.length;
  }
}

const pastEditions = editions.filter((e: any) => e.file.replace('.json', '') !== latestKey);
const editionLabel = edition === 'morning' ? '早报' : edition === 'evening' ? '晚报' : '';
const editionIcon = edition === 'morning' ? '☀️' : edition === 'evening' ? '🌙' : '📰';
---

<Layout title={`Woody News — ${editionLabel || '每日新闻'}`}>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
    <div class="mb-6">
      <p class="text-sm text-[var(--text-muted)] flex flex-wrap items-center gap-y-2">
        {(() => {
          if (!newsDate) return '暂无数据';
          const d = new Date(`${newsDate}T00:00:00`);
          const weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
          return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日（${weekdays[d.getDay()]}）`;
        })()}
        {editionLabel && (
          <span class="ml-1 inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium bg-[var(--tag-bg)] text-[var(--tag-text)]">
            {editionIcon} {editionLabel}
          </span>
        )}
        <span class="ml-2">
          共 <span id="topic-count">{clusterCount}</span> 个主题 · <span id="article-count">{articleCount}</span> 条报道
        </span>
      </p>
    </div>

    <NewsFeed
      categories={categories}
      articles={articles}
      clusters={clusters}
      emptyTitle="今日暂无新闻"
      emptyDescription="新闻将在每天 08:00 和 20:00 自动更新"
    />

    {pastEditions.length > 0 && (
      <section class="mt-16">
        <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <span>📅</span>
          <span>往期新闻</span>
        </h2>
        <div class="flex flex-wrap gap-2">
          {pastEditions.slice(0, 30).map((e: any) => {
            const d = new Date(`${e.date}T00:00:00`);
            const weekdays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
            const eLabel = e.edition === 'morning' ? '☀️早报' : e.edition === 'evening' ? '🌙晚报' : '';
            const key = e.file.replace('.json', '');
            return (
              <a
                href={`/archive/${key}`}
                class="px-4 py-2 text-sm rounded-lg border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
              >
                {`${d.getMonth() + 1}月${d.getDate()}日（${weekdays[d.getDay()]}）${eLabel}`}
              </a>
            );
          })}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>
