---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NewsFeed from '../../components/NewsFeed.astro';
import fs from 'node:fs';
import path from 'node:path';

const categoriesPath = path.join(process.cwd(), 'config/categories.json');
const categoriesData = JSON.parse(fs.readFileSync(categoriesPath, 'utf-8'));
const categories = categoriesData.categories;

const indexPath = path.join(process.cwd(), 'data/index.json');
let editions: any[] = [];
if (fs.existsSync(indexPath)) {
  const indexData = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
  editions = indexData.editions || [];
  if (!editions.length && indexData.dates) {
    editions = indexData.dates.map((d: string) => ({ date: d, edition: 'all', file: `${d}.json` }));
  }
}

export function getStaticPaths() {
  const indexPath2 = path.join(process.cwd(), 'data/index.json');
  if (!fs.existsSync(indexPath2)) return [];
  const indexData = JSON.parse(fs.readFileSync(indexPath2, 'utf-8'));
  const eds = indexData.editions || [];
  if (!eds.length && indexData.dates) {
    return indexData.dates.map((d: string) => ({ params: { date: d } }));
  }
  return eds.map((e: any) => ({ params: { date: e.file.replace('.json', '') } }));
}

const { date } = Astro.params;

let articles: any[] = [];
let clusters: any[] = [];
let newsDate = '';
let edition = '';
let articleCount = 0;
let clusterCount = 0;
const dataPath = path.join(process.cwd(), `data/${date}.json`);
if (fs.existsSync(dataPath)) {
  const data = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  articles = data.articles || [];
  clusters = data.clusters || [];
  newsDate = data.date || date;
  edition = data.edition || '';
  articleCount = data.article_count || articles.length;
  clusterCount = data.cluster_count || clusters.length || articles.length;
}

const currentKey = date;
const otherEditions = editions.filter((e: any) => e.file.replace('.json', '') !== currentKey);
const editionLabel = edition === 'morning' ? '早报' : edition === 'evening' ? '晚报' : '';
const editionIcon = edition === 'morning' ? '☀️' : edition === 'evening' ? '🌙' : '📰';
---

<Layout title={`${newsDate || date} ${editionLabel} — Woody News`}>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
    <nav class="mb-6 flex items-center gap-2 text-sm text-[var(--text-muted)]">
      <a href="/" class="hover:text-[var(--accent)] transition-colors">首页</a>
      <span>›</span>
      <span class="text-[var(--text-primary)]">往期新闻</span>
    </nav>

    <div class="mb-6">
      <h1 class="text-2xl font-bold mb-1 flex flex-wrap items-center gap-x-2 gap-y-2">
        {(() => {
          const dateStr = newsDate || date;
          const d = new Date(`${dateStr}T00:00:00`);
          const weekdays = ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'];
          return `${d.getFullYear()}年${d.getMonth() + 1}月${d.getDate()}日（${weekdays[d.getDay()]}）`;
        })()}
        {editionLabel && (
          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-sm font-medium bg-[var(--tag-bg)] text-[var(--tag-text)]">
            {editionIcon} {editionLabel}
          </span>
        )}
      </h1>
      <p class="text-sm text-[var(--text-muted)]">
        共 <span id="topic-count">{clusterCount}</span> 个主题 · <span id="article-count">{articleCount}</span> 条报道
      </p>
    </div>

    <NewsFeed
      categories={categories}
      articles={articles}
      clusters={clusters}
      emptyTitle="该期暂无新闻数据"
    />

    {otherEditions.length > 0 && (
      <section class="mt-16">
        <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <span>📅</span><span>其他期次</span>
        </h2>
        <div class="flex flex-wrap gap-2">
          {otherEditions.slice(0, 30).map((e: any) => {
            const dt = new Date(`${e.date}T00:00:00`);
            const weekdays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
            const eLabel = e.edition === 'morning' ? '☀️早报' : e.edition === 'evening' ? '🌙晚报' : '';
            const key = e.file.replace('.json', '');
            return (
              <a
                href={`/archive/${key}`}
                class="px-4 py-2 text-sm rounded-lg border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
              >
                {`${dt.getMonth() + 1}月${dt.getDate()}日（${weekdays[dt.getDay()]}）${eLabel}`}
              </a>
            );
          })}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>
