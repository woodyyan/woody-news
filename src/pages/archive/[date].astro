---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

// 读取分类配置
const categoriesPath = path.join(process.cwd(), 'config/categories.json');
const categoriesData = JSON.parse(fs.readFileSync(categoriesPath, 'utf-8'));
const categories = categoriesData.categories;

// 读取日期索引
const indexPath = path.join(process.cwd(), 'data/index.json');
let availableDates: string[] = [];
if (fs.existsSync(indexPath)) {
  const indexData = JSON.parse(fs.readFileSync(indexPath, 'utf-8'));
  availableDates = indexData.dates || [];
}

// 生成所有日期的静态路径
export function getStaticPaths() {
  const indexPath2 = path.join(process.cwd(), 'data/index.json');
  if (!fs.existsSync(indexPath2)) return [];
  const indexData = JSON.parse(fs.readFileSync(indexPath2, 'utf-8'));
  return (indexData.dates || []).map((date: string) => ({
    params: { date },
  }));
}

const { date } = Astro.params;

// 读取对应日期的新闻
let articles: any[] = [];
const dataPath = path.join(process.cwd(), `data/${date}.json`);
if (fs.existsSync(dataPath)) {
  const data = JSON.parse(fs.readFileSync(dataPath, 'utf-8'));
  articles = data.articles || [];
}
---

<Layout title={`${date} 新闻 — Woody News`}>
  <Header />

  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-6">
    {/* 面包屑 */}
    <nav class="mb-6 flex items-center gap-2 text-sm text-[var(--text-muted)]">
      <a href="/" class="hover:text-[var(--accent)] transition-colors">首页</a>
      <span>›</span>
      <span class="text-[var(--text-primary)]">{date}</span>
    </nav>

    {/* 日期 & 统计 */}
    <div class="mb-6">
      <h1 class="text-2xl font-bold mb-1">{date}</h1>
      <p class="text-sm text-[var(--text-muted)]">
        共 <span id="article-count">{articles.length}</span> 条新闻
      </p>
    </div>

    {/* 分类 Tab */}
    <nav class="flex gap-1 mb-8 overflow-x-auto pb-2 scrollbar-hide border-b border-[var(--border-color)]" id="category-tabs">
      <button
        class="tab-btn tab-active px-4 py-2 text-sm whitespace-nowrap transition-colors rounded-t-lg"
        data-category="all"
      >
        全部
      </button>
      {categories.map((cat: any) => (
        <button
          class="tab-btn px-4 py-2 text-sm whitespace-nowrap text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors rounded-t-lg"
          data-category={cat.id}
        >
          <span class="mr-1">{cat.icon}</span>{cat.name}
        </button>
      ))}
    </nav>

    {/* 新闻列表 */}
    {articles.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="news-grid">
        {articles.map((article: any) => (
          <article class="card group cursor-pointer" data-category={article.category}>
            <a href={article.link} target="_blank" rel="noopener noreferrer" class="block">
              {article.image ? (
                <div class="aspect-[16/9] overflow-hidden bg-[var(--bg-secondary)]">
                  <img
                    src={article.image}
                    alt={article.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    onerror="this.closest('.card').querySelector('.img-fallback')?.classList.remove('hidden'); this.parentElement.classList.add('hidden');"
                  />
                </div>
              ) : null}
              <div class:list={[
                "img-fallback aspect-[16/9] relative overflow-hidden flex flex-col items-center justify-center",
                article.image ? "hidden" : "",
                article.category === 'world' ? 'bg-gradient-to-br from-blue-500 via-indigo-500 to-purple-600' :
                article.category === 'china' ? 'bg-gradient-to-br from-rose-500 via-red-500 to-orange-500' :
                article.category === 'tech' ? 'bg-gradient-to-br from-violet-500 via-purple-500 to-fuchsia-600' :
                'bg-gradient-to-br from-emerald-500 via-teal-500 to-cyan-600'
              ]}>
                <div class="absolute inset-0 opacity-10">
                  <div class="absolute top-4 left-4 w-24 h-24 rounded-full border-2 border-white/30"></div>
                  <div class="absolute bottom-6 right-6 w-16 h-16 rounded-full border-2 border-white/20"></div>
                  <div class="absolute top-1/2 right-1/4 w-8 h-8 rounded-full bg-white/10"></div>
                </div>
                <span class="text-4xl mb-2 drop-shadow-lg relative z-10">
                  {categories.find((c: any) => c.id === article.category)?.icon || '📰'}
                </span>
                <span class="text-white/90 text-sm font-medium tracking-wide relative z-10">{article.source}</span>
              </div>
              <div class="p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`category-badge ${
                    article.category === 'world' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300' :
                    article.category === 'china' ? 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300' :
                    article.category === 'tech' ? 'bg-purple-100 text-purple-700 dark:bg-purple-900/40 dark:text-purple-300' :
                    'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300'
                  }`}>
                    {categories.find((c: any) => c.id === article.category)?.name || article.category}
                  </span>
                  {article.lang === 'en' && (
                    <span class="tag-translated" title="已从英文翻译">译</span>
                  )}
                </div>
                <h2 class="text-base font-semibold leading-snug mb-2 text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors line-clamp-2">
                  {article.title}
                </h2>
                {article.lang === 'en' && article.title_original && (
                  <p class="text-xs text-[var(--text-muted)] mb-2 line-clamp-1 italic">
                    {article.title_original}
                  </p>
                )}
                <p class="text-sm text-[var(--text-secondary)] leading-relaxed mb-3 line-clamp-3">
                  {article.summary}
                </p>
                <div class="flex items-center justify-between text-xs text-[var(--text-muted)]">
                  <span>{article.source}</span>
                  <time datetime={article.published_at}>
                    {new Date(article.published_at).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}
                  </time>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="text-5xl mb-4">📭</div>
        <p class="text-lg text-[var(--text-secondary)]">该日期暂无新闻数据</p>
      </div>
    )}

    {/* 其他日期 */}
    {availableDates.length > 1 && (
      <section class="mt-16">
        <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <span>📅</span><span>其他日期</span>
        </h2>
        <div class="flex flex-wrap gap-2">
          {availableDates.filter(d => d !== date).slice(0, 30).map((d: string) => (
            <a
              href={`/archive/${d}`}
              class="px-4 py-2 text-sm rounded-lg border border-[var(--border-color)] text-[var(--text-secondary)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
            >
              {d}
            </a>
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<script is:inline>
  const tabs = document.querySelectorAll('.tab-btn');
  const cards = document.querySelectorAll('#news-grid [data-category]');
  const countEl = document.getElementById('article-count');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('tab-active');
        t.classList.add('text-[var(--text-secondary)]');
      });
      tab.classList.add('tab-active');
      tab.classList.remove('text-[var(--text-secondary)]');
      const category = tab.dataset.category;
      let visibleCount = 0;
      cards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      if (countEl) countEl.textContent = visibleCount.toString();
    });
  });
</script>

<style>
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .line-clamp-1 { display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>
